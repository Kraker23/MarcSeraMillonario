@page
@model ResumenModel
@{
    ViewData["Title"] = "Certificado de Marido";
}

<style>
    body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    .resumen-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .certificado {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        border: 10px solid #ffd700;
        border-radius: 20px;
        max-width: 900px;
        width: 100%;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4),
                    0 0 0 3px #fff,
                    0 0 0 6px #ffd700,
                    inset 0 0 100px rgba(255, 215, 0, 0.1);
        position: relative;
        animation: fadeInScale 0.8s ease-out;
    }

    @@keyframes fadeInScale {
        from {
            opacity: 0;
            transform: scale(0.9);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .certificado::before {
        content: '🏆';
        position: absolute;
        top: 20px;
        left: 20px;
        font-size: 3rem;
        opacity: 0.2;
    }

    .certificado::after {
        content: '💍';
        position: absolute;
        bottom: 20px;
        right: 20px;
        font-size: 3rem;
        opacity: 0.2;
    }

    .cert-header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 3px solid #ffd700;
        padding-bottom: 20px;
    }

    .cert-title {
        font-size: 2.5rem;
        font-weight: bold;
        color: #2c3e50;
        margin-bottom: 10px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
    }

    .cert-subtitle {
        font-size: 1.2rem;
        color: #7f8c8d;
        font-style: italic;
    }

    .cert-date {
        font-size: 1rem;
        color: #95a5a6;
        margin-top: 10px;
        font-weight: normal;
    }

    .stats-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .stat-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .stat-label {
        font-size: 0.9rem;
        opacity: 0.9;
    }

    .nivel-alcanzado {
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        border: 3px solid #f39c12;
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(255, 215, 0, 0.3);
    }

    .nivel-alcanzado h2 {
        color: #2c3e50;
        font-size: 2rem;
        margin: 0 0 10px 0;
    }

    .nivel-alcanzado .nivel-texto {
        font-size: 1.8rem;
        font-weight: bold;
        color: #16a085;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
    }

    .historial-section {
        margin-bottom: 30px;
    }

    .historial-title {
        font-size: 1.8rem;
        color: #2c3e50;
        margin-bottom: 20px;
        text-align: center;
        font-weight: bold;
    }

    .pregunta-card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 15px;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

    .pregunta-card:hover {
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        transform: translateX(5px);
    }

    .pregunta-card.correcta {
        border-left: 5px solid #27ae60;
        background: linear-gradient(to right, rgba(39, 174, 96, 0.05), #fff);
    }

    .pregunta-card.incorrecta {
        border-left: 5px solid #e74c3c;
        background: linear-gradient(to right, rgba(231, 76, 60, 0.05), #fff);
    }

    .pregunta-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .pregunta-numero {
        font-weight: bold;
        color: #2c3e50;
        font-size: 1.1rem;
    }

    .resultado-badge {
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .resultado-badge.correcta {
        background: #27ae60;
        color: #fff;
    }

    .resultado-badge.incorrecta {
        background: #e74c3c;
        color: #fff;
    }

    .pregunta-texto {
        font-size: 1.1rem;
        color: #34495e;
        margin-bottom: 15px;
        font-weight: 500;
    }

    .respuesta-item {
        padding: 10px 15px;
        margin: 8px 0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .respuesta-dada {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        color: #fff;
        font-weight: bold;
    }

    .respuesta-correcta {
        background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
        color: #fff;
        font-weight: bold;
    }

    .comodin-usado {
        display: inline-block;
        background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
        color: #fff;
        padding: 8px 20px;
        border-radius: 25px;
        font-size: 0.9rem;
        margin-top: 10px;
        box-shadow: 0 3px 10px rgba(155, 89, 182, 0.4);
        display: flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
    }

    .comodin-icono {
        font-size: 1.2rem;
    }

    .comodin-texto {
        font-weight: 500;
    }

    .chupitos-info {
        margin-top: 10px;
        padding: 10px;
        background: rgba(52, 152, 219, 0.1);
        border-radius: 8px;
        font-size: 0.95rem;
        color: #2c3e50;
    }

    .chupito-detalle {
        font-style: italic;
        color: #7f8c8d;
    }

    .actions-section {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 15px 40px;
        font-size: 1.2rem;
        font-weight: bold;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-nuevo {
        background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
        color: #fff;
        box-shadow: 0 5px 15px rgba(39, 174, 96, 0.4);
    }

    .btn-nuevo:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(39, 174, 96, 0.6);
    }

    .btn-home {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        color: #fff;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.4);
    }

    .btn-home:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(52, 152, 219, 0.6);
    }

    .btn-print {
        background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
        color: #fff;
        box-shadow: 0 5px 15px rgba(230, 126, 34, 0.4);
    }

    .btn-print:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(230, 126, 34, 0.6);
    }

    @@media print {
        .resumen-container {
            padding: 0;
            background: #fff;
        }

        .actions-section {
            display: none;
        }

        .certificado {
            box-shadow: none;
            border: 5px solid #ffd700;
        }
    }

    @@media (max-width: 768px) {
        .certificado {
            padding: 20px;
        }

        .cert-title {
            font-size: 1.8rem;
        }

        .stats-section {
            grid-template-columns: 1fr;
        }

        .pregunta-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }
    }
</style>

<div class="resumen-container">
    <div class="certificado">
        <div class="cert-header">
            <div class="cert-title">🏆 CERTIFICADO OFICIAL DE MARIDO 💍</div>
            <div class="cert-subtitle">¿Quién Quiere Ser el Mejor Marido?</div>
            <div class="cert-date">Fecha: @DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>

        <div class="nivel-alcanzado">
            <h2>🎖️ Nivel Alcanzado</h2>
            <div class="nivel-texto">@Model.Resumen.NivelAlcanzado</div>
        </div>

        <div class="stats-section">
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-value">@Model.Resumen.PreguntasCorrectas</div>
                <div class="stat-label">Respuestas Correctas</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">❌</div>
                <div class="stat-value">@Model.Resumen.PreguntasIncorrectas</div>
                <div class="stat-label">Respuestas Incorrectas</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🎯</div>
                <div class="stat-value">@Model.Resumen.ComodinesUsados</div>
                <div class="stat-label">Comodines Usados</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🍺</div>
                <div class="stat-value">@Model.Resumen.TotalChupitos</div>
                <div class="stat-label">Total Chupitos</div>
            </div>
        </div>

        <div class="historial-section">
            <h3 class="historial-title">📋 Historial Detallado</h3>
            
            @foreach (var item in Model.Resumen.Historial)
            {
                <div class="pregunta-card @(item.FueCorrecta ? "correcta" : "incorrecta")">
                    <div class="pregunta-header">
                        <span class="pregunta-numero">Pregunta @item.NumeroPregunta</span>
                        <div class="resultado-badge @(item.FueCorrecta ? "correcta" : "incorrecta")">
                            <span>@(item.FueCorrecta ? "✅" : "❌")</span>
                            <span>@(item.FueCorrecta ? "CORRECTA" : "INCORRECTA")</span>
                        </div>
                    </div>

                    <div class="pregunta-texto">@item.TextoPregunta</div>

                    <div class="respuesta-item respuesta-dada">
                        <span>📝</span>
                        <span><strong>Tu respuesta:</strong> @item.RespuestaDada</span>
                    </div>

                    @if (!item.FueCorrecta)
                    {
                        <div class="respuesta-item respuesta-correcta">
                            <span>✔️</span>
                            <span><strong>Respuesta correcta:</strong> @item.RespuestaCorrecta</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(item.ComodinUsado))
                    {
                        <div class="comodin-usado">
                            <span class="comodin-icono">@item.ComodinUsado</span>
                            <span class="comodin-texto">Comodín usado en esta pregunta</span>
                        </div>
                    }

                    <div class="chupitos-info">
                        <strong>🍺 Chupitos generados:</strong> @item.ChupitosGenerados
                        @if (item.FueCorrecta)
                        {
                            <span class="chupito-detalle"> - (1 para ti 🥃 + 1 para otro 🥃)</span>
                        }
                        else if (!string.IsNullOrEmpty(item.ComodinUsado))
                        {
                            <span class="chupito-detalle"> - (¡Fallo con comodín = Castigo doble! 😱)</span>
                        }
                        else
                        {
                            <span class="chupito-detalle"> - (Por fallo)</span>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="actions-section">
            <a asp-page="/Index" class="btn-action btn-home">🏠 Inicio</a>
            <form method="post" asp-page-handler="NuevoJuego" style="margin: 0;">
                <button type="submit" class="btn-action btn-nuevo">🎮 Nuevo Juego</button>
            </form>
            <button onclick="window.print()" class="btn-action btn-print">🖨️ Imprimir Certificado</button>
        </div>
    </div>
</div>
